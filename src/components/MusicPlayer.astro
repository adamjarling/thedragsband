---
import { t } from '../i18n/utils';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;
---

<section id="music" class="music-section">
  <img
    src="/images/IMG_9554.jpeg"
    alt=""
    class="music-bg"
    aria-hidden="true"
    loading="lazy"
  />
  <div class="music-overlay"></div>

  <div class="music-content">
    <p class="music-label">{t(lang, 'music.label')}</p>
    <h2 class="music-track">{t(lang, 'music.track')}</h2>
    <audio
      class="music-audio"
      controls
      preload="none"
      src="/audio/blues-jam-1.m4a"
    >
      Your browser does not support the audio element.
    </audio>
  </div>
</section>

<style>
  .music-section {
    position: relative;
    width: 100%;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .music-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) brightness(0.25) contrast(1.1);
  }

  .music-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.5) 0%,
      rgba(0,0,0,0.2) 50%,
      rgba(0,0,0,0.5) 100%
    );
  }

  .music-content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .music-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  .music-track {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    color: #ffffff;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .music-audio {
    width: min(420px, 90vw);
    filter: invert(1) brightness(0.75);
  }
</style>
