---
import { t } from '../i18n/utils';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;
---

<section id="music" class="section">
  <h2 class="section-heading">{t(lang, 'music.heading')}</h2>

  <div class="music-player">
    <p class="player-track-name">{t(lang, 'music.track')}</p>
    <p class="player-label">{t(lang, 'music.label')}</p>
    <audio
      class="player-audio"
      controls
      preload="none"
      src="/audio/blues-jam-1.m4a"
    >
      Your browser does not support the audio element.
    </audio>
  </div>
</section>
