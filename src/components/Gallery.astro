---
import { t } from "../i18n/utils";

interface Props {
  lang: "de" | "en";
}

const { lang } = Astro.props;

const photos = [
  { src: "/images/alex-stefan-chilling.jpeg", alt: "The Drags" },
  // { src: "/images/IMG_1081.JPG", alt: "The Drags" },
  // { src: "/images/guitar-screen-shot.png", alt: "The Drags" },
  { src: "/images/lill-singing-edited.png", alt: "The Drags" },
  { src: "/images/IMG_1084.JPG", alt: "The Drags" },
  { src: "/images/IMG_9554.jpeg", alt: "The Drags" },
  { src: "/images/IMG_1033.jpg", alt: "The Drags" },
  { src: "/images/674179262_4316869891974648_8757351351663698479_n.jpg", alt: "The Drags" },
  { src: "/images/674582433_4316869388641365_4163761276374460983_n.jpg", alt: "The Drags" },
  { src: "/images/675791807_4316869621974675_8272766122137894808_n.jpg", alt: "The Drags" },
  { src: "/images/677254653_4316869155308055_4397627386105333027_n.jpg", alt: "The Drags" },
  { src: "/images/677257479_4316869355308035_3448653469414273722_n.jpg", alt: "The Drags" },
  { src: "/images/677925938_4316869271974710_5530924666295572768_n.jpg", alt: "The Drags" },
  { src: "/images/677927990_4316869245308046_7291756835387345483_n.jpg", alt: "The Drags" },
];
---

<section id="gallery" class="section">
  <h2 class="section-heading sr-only">{t(lang, "gallery.heading")}</h2>

  <div class="gallery-masonry">
    {
      photos.map((photo, i) => (
        <div class="gallery-item">
          <button class="gallery-trigger" data-index={i} aria-label={`Open photo ${i + 1}`}>
            <img src={photo.src} alt={photo.alt} loading="lazy" />
          </button>
        </div>
      ))
    }
  </div>

  <p class="photo-credits">
    Photos by <a href="https://www.facebook.com/profile.php?id=100009550403171" target="_blank" rel="noopener noreferrer">Peter Kogoj</a> &amp; <a href="https://www.instagram.com/caseymolloymurtaugh/" target="_blank" rel="noopener noreferrer">Casey Murtaugh</a>
  </p>
</section>

<dialog class="lightbox" id="lightbox" aria-label="Photo viewer">
  <div class="lightbox-inner">
    <img class="lightbox-img" src="" alt="" />
  </div>
  <button class="lightbox-btn lightbox-prev" aria-label="Previous photo">&#8592;</button>
  <button class="lightbox-btn lightbox-next" aria-label="Next photo">&#8594;</button>
  <button class="lightbox-close" aria-label="Close">&#10005;</button>
</dialog>

<style>
  /* Mobile: natural dimensions, stacked */
  .gallery-masonry {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .gallery-trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: auto;
    filter: grayscale(1) contrast(1.1) brightness(0.85);
    transition: filter 0.4s ease;
  }

  .gallery-trigger:hover img,
  .gallery-trigger:focus-visible img {
    filter: grayscale(1) contrast(1.2) brightness(1);
  }

  /* Tablet and up: CSS columns masonry, no cropping */
  @media (min-width: 640px) {
    .gallery-masonry {
      display: block;
      columns: 2;
      column-gap: 0.5rem;
    }

    .gallery-item {
      break-inside: avoid;
      margin-bottom: 0.5rem;
    }
  }

  @media (min-width: 960px) {
    .gallery-masonry {
      columns: 3;
    }
  }

  .photo-credits {
    margin-top: 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  .photo-credits a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .photo-credits a:hover {
    opacity: 0.8;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: rgba(0, 0, 0, 0.92);
  }

  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox::backdrop {
    background: transparent;
  }

  .lightbox-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 3rem 4rem;
    box-sizing: border-box;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale(1) contrast(1.1);
    display: block;
  }

  .lightbox-btn,
  .lightbox-close {
    position: absolute;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    font-size: 1.25rem;
    line-height: 1;
    padding: 0.75rem;
    transition: color 0.2s ease;
  }

  .lightbox-btn:hover,
  .lightbox-close:hover {
    color: #fff;
  }

  .lightbox-prev { left: 0.5rem; top: 50%; transform: translateY(-50%); font-size: 1.75rem; }
  .lightbox-next { right: 0.5rem; top: 50%; transform: translateY(-50%); font-size: 1.75rem; }
  .lightbox-close { top: 0.75rem; right: 0.75rem; font-size: 1rem; }
</style>

<script>
  const photos = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-trigger'));
  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const img = dialog.querySelector<HTMLImageElement>('.lightbox-img')!;
  const prevBtn = dialog.querySelector<HTMLButtonElement>('.lightbox-prev')!;
  const nextBtn = dialog.querySelector<HTMLButtonElement>('.lightbox-next')!;
  const closeBtn = dialog.querySelector<HTMLButtonElement>('.lightbox-close')!;

  let current = 0;

  function open(index: number) {
    current = index;
    const trigger = photos[current];
    const src = trigger.querySelector('img')!.src;
    const alt = trigger.querySelector('img')!.alt;
    img.src = src;
    img.alt = alt;
    dialog.showModal();
  }

  function navigate(delta: number) {
    current = (current + delta + photos.length) % photos.length;
    const trigger = photos[current];
    img.src = trigger.querySelector('img')!.src;
    img.alt = trigger.querySelector('img')!.alt;
  }

  photos.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
  prevBtn.addEventListener('click', () => navigate(-1));
  nextBtn.addEventListener('click', () => navigate(1));
  closeBtn.addEventListener('click', () => dialog.close());

  // Close on backdrop click
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });

  // Keyboard navigation
  dialog.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });
</script>
