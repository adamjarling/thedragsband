---
import { t } from '../i18n/utils';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;

const photos = [
  { src: '/images/alex-stefan-chilling.jpeg', alt: 'The Drags' },
  { src: '/images/IMG_1081.JPG', alt: 'The Drags' },
  { src: '/images/IMG_1084.JPG', alt: 'The Drags' },
  { src: '/images/lill-singing-edited.png', alt: 'The Drags' },
  { src: '/images/band-photo-4.JPG', alt: 'The Drags' },
];
---

<section id="gallery" class="section">
  <h2 class="section-heading">{t(lang, 'gallery.heading')}</h2>

  <div class="gallery-masonry">
    {photos.map((photo) => (
      <div class="gallery-item">
        <img src={photo.src} alt={photo.alt} loading="lazy" />
      </div>
    ))}
  </div>
</section>

<style>
  /* Mobile: natural dimensions, stacked */
  .gallery-masonry {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: auto;
    filter: grayscale(1) contrast(1.1) brightness(0.85);
    transition: filter 0.4s ease;
  }

  .gallery-item:hover img {
    filter: grayscale(1) contrast(1.2) brightness(1);
  }

  /* Tablet and up: CSS columns masonry, no cropping */
  @media (min-width: 640px) {
    .gallery-masonry {
      display: block;
      columns: 2;
      column-gap: 0.5rem;
    }

    .gallery-item {
      break-inside: avoid;
      margin-bottom: 0.5rem;
    }
  }

  @media (min-width: 960px) {
    .gallery-masonry {
      columns: 3;
    }
  }
</style>
