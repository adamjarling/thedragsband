---
import { t } from '../i18n/utils';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;

const photos = [
  { src: '/images/lill-onstage-1.png', alt: 'The Drags live' },
  { src: '/images/IMG_9554.jpeg', alt: 'The Drags' },
  { src: '/images/IMG_9148.jpeg', alt: 'The Drags' },
  { src: '/images/IMG_1081.JPG', alt: 'The Drags' },
  { src: '/images/IMG_1084.JPG', alt: 'The Drags' },
  { src: '/images/band-photo-4.JPG', alt: 'The Drags' },
];
---

<section id="gallery" class="section">
  <h2 class="section-heading">{t(lang, 'gallery.heading')}</h2>

  <div class="gallery-grid">
    {photos.map((photo) => (
      <div class="gallery-item">
        <img src={photo.src} alt={photo.alt} loading="lazy" />
      </div>
    ))}
  </div>
</section>
