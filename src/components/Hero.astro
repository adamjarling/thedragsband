---
---

<section class="hero" aria-label="Hero">
  <img
    src="/images/hapsburgs.jpeg"
    alt=""
    class="hero-bg"
    aria-hidden="true"
    loading="eager"
  />

  <div class="hero-content">
    <img
      src="/images/the-drags-logo-textured.svg"
      alt="The Drags"
      class="hero-logo"
    />
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) brightness(0.3);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 2rem;
  }

  .hero-logo {
    width: clamp(240px, 50vw, 520px);
    filter: brightness(0) invert(1);
    animation: logo-lightning 1.8s ease-out forwards;
  }

  @keyframes logo-lightning {
    0%   { opacity: 0;   filter: brightness(0) invert(1);                                                                  transform: translate(0, 0); }
    4%   { opacity: 1;   filter: brightness(5) invert(1) drop-shadow(0 0 30px #fff) drop-shadow(0 0 70px rgba(180,200,255,0.9)); transform: translate(-3px,  1px); }
    6%   { opacity: 0;   filter: brightness(0) invert(1);                                                                  transform: translate( 2px, -1px); }
    10%  { opacity: 1;   filter: brightness(7) invert(1) drop-shadow(0 0 50px #fff) drop-shadow(0 0 110px rgba(160,185,255,0.7)); transform: translate( 3px,  2px); }
    12%  { opacity: 0.1; filter: brightness(1) invert(1);                                                                  transform: translate(-1px,  1px); }
    16%  { opacity: 1;   filter: brightness(6) invert(1) drop-shadow(0 0 40px #fff);                                       transform: translate(-2px, -2px); }
    18%  { opacity: 0;   filter: brightness(0) invert(1);                                                                  transform: translate( 1px,  0);   }
    22%  { opacity: 1;   filter: brightness(9) invert(1) drop-shadow(0 0 80px #fff) drop-shadow(0 0 40px rgba(210,225,255,1));  transform: translate( 0,    0);   }
    26%  { opacity: 0.7; filter: brightness(4) invert(1) drop-shadow(0 0 25px rgba(255,255,255,0.8));                      transform: translate( 1px, -1px); }
    32%  { opacity: 1;   filter: brightness(2) invert(1) drop-shadow(0 0 12px rgba(255,255,255,0.5));                      transform: translate( 0,    0);   }
    44%  { opacity: 1;   filter: brightness(1.2) invert(1) drop-shadow(0 0 6px rgba(255,255,255,0.2));                     transform: translate( 0,    0);   }
    65%  { opacity: 1;   filter: brightness(0.6) invert(1);                                                                transform: translate( 0,    0);   }
    100% { opacity: 1;   filter: brightness(0) invert(1);                                                                  transform: translate( 0,    0);   }
  }
</style>
