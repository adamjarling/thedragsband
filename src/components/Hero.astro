---
import { t } from '../i18n/utils';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;
---

<section class="hero" aria-label="Hero">
  <img
    src="/images/hapsburgs.jpeg"
    alt=""
    class="hero-bg"
    aria-hidden="true"
    loading="eager"
  />

  <div class="hero-content">
    <img
      src="/images/the-drags-logo-textured.svg"
      alt="The Drags"
      class="hero-logo"
    />
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) brightness(0.3);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 2rem;
  }

  .hero-logo {
    width: clamp(240px, 50vw, 520px);
    filter: brightness(0) invert(1);
  }
</style>
