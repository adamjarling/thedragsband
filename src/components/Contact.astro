---
import { t } from '../i18n/utils';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;
---

<section id="contact" class="section">
  <h2 class="section-heading">{t(lang, 'contact.heading')}</h2>

  <div class="contact-inner">
    <p class="contact-text">{t(lang, 'contact.text')}</p>
    <a href={`mailto:${t(lang, 'contact.email')}`} class="contact-email-link">
      {t(lang, 'contact.email')}
    </a>
    <p class="contact-subtext">{t(lang, 'contact.subtext')}</p>
  </div>
</section>
