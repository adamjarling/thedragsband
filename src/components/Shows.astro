---
import { t } from "../i18n/utils";

interface Props {
  lang: "de" | "en";
}

const { lang } = Astro.props;
---

<section id="shows" class="section">
  <h2 class="section-heading">{t(lang, "shows.heading")}</h2>

  <div class="show-listing">
    <p class="show-date">{t(lang, "shows.date")}</p>
    <p class="show-venue">{t(lang, "shows.venue")}</p>
    <p class="show-city">{t(lang, "shows.city")}</p>
    <p class="show-meta">{t(lang, "shows.time")} &nbsp;·&nbsp; {t(lang, "shows.price")}</p>
    <a href="https://www.cafe-carina.at/2020/events/the-drags-deloreans/" target="_blank" rel="noopener" class="show-cta">{t(lang, "shows.tickets")}</a>
  </div>

  <div class="flyer-compare">
    <img
      src="/images/2026-04-18-carina_FINAL.jpeg"
      alt="Flyer for Cafe Carina show on April 18, 2026"
      class="flyer-img"
    />
  </div>
</section>
