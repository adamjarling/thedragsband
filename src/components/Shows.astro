---
import { t } from "../i18n/utils";

interface Props {
  lang: "de" | "en";
}

const { lang } = Astro.props;

const showsData = [
  {
    date: "Saturday, April 18, 2026",
    dateObj: new Date("2026-04-18"),
    venue: "Café Carina",
    city: "Vienna, Austria",
    time: "8:00 PM",
    price: "Pass the hat — pay what you like",
    ticketUrl: "https://www.cafe-carina.at/2020/events/the-drags-deloreans/",
    flyer: "/images/2026-04-18-carina_FINAL.jpeg",
    flyerAlt: "Flyer for Cafe Carina show on April 18, 2026"
  },
  {
    date: "Friday, June 19, 2026",
    dateObj: new Date("2026-06-19"),
    venue: "Café Carina",
    city: "Vienna, Austria",
    time: "8:00 PM",
    price: "Pass the hat — pay what you like",
    ticketUrl: "https://www.cafe-carina.at/2020/events/the-drags/",
    flyer: "/images/2026-06-19_carina-flyer.jpg",
    flyerAlt: "Flyer for Cafe Carina show on June 19, 2026"
  }
];

const now = new Date();
const shows = showsData.sort((a, b) => b.dateObj.getTime() - a.dateObj.getTime()).map(show => ({
  ...show,
  isPast: show.dateObj < now
}));
---

<section id="shows" class="section">
  <h2 class="section-heading">{t(lang, "shows.heading")}</h2>

  {shows.map((show) => (
    <div class={`show-listing ${show.isPast ? 'show-past' : ''}`}>
      <p class="show-date">{show.date}</p>
      <p class="show-venue">{show.venue}</p>
      <p class="show-city">{show.city}</p>
      <p class="show-meta">{show.time} &nbsp;·&nbsp; {show.price}</p>
      <a href={show.ticketUrl} target="_blank" rel="noopener" class="show-cta">{t(lang, "shows.tickets")}</a>
      {show.flyer && (
        <div class="flyer-compare">
          <img
            src={show.flyer}
            alt={show.flyerAlt}
            class="flyer-img"
          />
        </div>
      )}
    </div>
  ))}
</section>

<style>
  @media (min-width: 960px) {
    .show-past .flyer-compare {
      max-width: 50%;
    }
  }
</style>
