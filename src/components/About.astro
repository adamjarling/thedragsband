---
import { t } from '../i18n/utils';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;
---

<section id="about" class="section">
  <h2 class="section-heading">{t(lang, 'about.heading')}</h2>
  <div class="about-inner">
    <p class="about-bio">{t(lang, 'about.bio')}</p>
    <img
      src="/images/alex-stefan-chilling.jpeg"
      alt="The Drags"
      class="about-photo"
      loading="lazy"
    />
  </div>
</section>
