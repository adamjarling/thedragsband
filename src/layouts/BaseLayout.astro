---
import '../styles/global.css';

interface Props {
  title?: string;
  lang?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = 'The Drags',
  lang = 'de',
  description = 'The Drags – Blues Garage Rock aus Wien.',
  canonicalUrl = 'https://www.thedragsband.com/',
} = Astro.props;

const ogImage = 'https://www.thedragsband.com/images/the-drags-logo-solid.png';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href="/favicon_io/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon_io/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon_io/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="499" />
    <meta property="og:image:height" content="445" />
    <meta property="og:locale" content={lang === 'de' ? 'de_AT' : 'en_US'} />
    <meta property="og:site_name" content="The Drags" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Alternate language links -->
    {lang === 'de' && <link rel="alternate" hreflang="en" href="https://www.thedragsband.com/en/" />}
    {lang === 'en' && <link rel="alternate" hreflang="de" href="https://www.thedragsband.com/" />}
    <link rel="alternate" hreflang="x-default" href="https://www.thedragsband.com/" />

    <!-- MusicGroup structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MusicGroup",
      "name": "The Drags",
      "description": "Blues Garage Rock band from Vienna, Austria.",
      "url": "https://www.thedragsband.com",
      "image": ogImage,
      "genre": ["Blues", "Garage Rock"],
      "foundingLocation": {
        "@type": "Place",
        "name": "Vienna, Austria"
      }
    })} />
  </head>
  <body>
    <!-- CRT noise layer -->
    <div class="crt-noise" aria-hidden="true"></div>
    <!-- CRT scanline + vignette overlay -->
    <div class="crt-overlay" aria-hidden="true"></div>

    <slot />
  </body>
</html>
