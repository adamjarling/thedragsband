---
import '../styles/global.css';

interface Props {
  title?: string;
  lang?: string;
  description?: string;
}

const {
  title = 'The Drags',
  lang = 'de',
  description = 'The Drags – Blues Garage Rock aus Wien.',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/images/the-drags-logo-textured.svg" />
    <!-- Alternate language links -->
    {lang === 'de' && <link rel="alternate" hreflang="en" href="/en/" />}
    {lang === 'en' && <link rel="alternate" hreflang="de" href="/" />}
    <link rel="alternate" hreflang="x-default" href="/" />
  </head>
  <body>
    <!-- CRT noise layer -->
    <div class="crt-noise" aria-hidden="true"></div>
    <!-- CRT scanline + vignette overlay -->
    <div class="crt-overlay" aria-hidden="true"></div>

    <slot />
  </body>
</html>
